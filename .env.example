# ╔══════════════════════════════════════════════════════════════╗
# ║              MarkOS UI — Environment Configuration          ║
# ╚══════════════════════════════════════════════════════════════╝
#
# Copy this file to `.env` in the same directory, then edit.
#
#   cp .env.example .env
#   nano .env
#
# After editing, restart the services:
#
#   docker compose down && docker compose up -d
#

# ──────────────────────────────────────────────────────────────
# UI Access
# ──────────────────────────────────────────────────────────────

# The port you open in a browser to access MarkOS UI.
# Example: http://your-server-ip:4173
MARKOS_UI_PORT=4173

# ──────────────────────────────────────────────────────────────
# OpenClaw Gateway Connection
# ──────────────────────────────────────────────────────────────

# Where is the OpenClaw gateway running?
#
# If the gateway runs on the SAME machine as Docker:
#   OPENCLAW_UPSTREAM_HOST=host.docker.internal   (default, works on Mac/Windows/Linux)
#
# If the gateway runs on a DIFFERENT machine:
#   OPENCLAW_UPSTREAM_HOST=192.168.1.100          (use the gateway machine's IP)
#
OPENCLAW_UPSTREAM_HOST=host.docker.internal

# The port the OpenClaw gateway listens on.
# This is the gateway's own port, NOT the UI port above.
# Default: 18789 — only change this if you changed the gateway config.
OPENCLAW_UPSTREAM_PORT=18789

# ──────────────────────────────────────────────────────────────
# Advanced (most users don't need to touch these)
# ──────────────────────────────────────────────────────────────

# Maximum request body size (file uploads, etc.)
# NGINX_CLIENT_MAX_BODY=16m

# WebSocket connection timeout in seconds.
# Increase if you have long-running agent sessions.
# NGINX_WS_TIMEOUT=300

# Enable gzip compression for the UI (on by default).
# Set to "off" to disable.
# NGINX_GZIP=on

# Vite base path — only change if you deploy under a subpath like /markos/
# VITE_BASE_PATH=/
