{
  "name": "markos-ui",
  "private": true,
  "version": "1.1.3",
  "description": "Agent Operating System UI for OpenClaw — Build, Monitor, and Orchestrate AI Agents Visually",
  "license": "MIT",
  "homepage": "https://github.com/mktt-ai-global/MarkOS-UI",
  "repository": {
    "type": "git",
    "url": "https://github.com/mktt-ai-global/MarkOS-UI.git"
  },
  "bugs": {
    "url": "https://github.com/mktt-ai-global/MarkOS-UI/issues"
  },
  "keywords": [
    "agent-os",
    "agent-ui",
    "ai-agents",
    "openclaw",
    "react",
    "vite",
    "orchestration"
  ],
  "engines": {
    "node": ">=22"
  },
  "type": "module",
  "scripts": {
    "dev": "vite",
    "test": "node --test --experimental-strip-types --experimental-specifier-resolution=node tests/*.test.ts",
    "typecheck": "tsc -b",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "check": "npm run lint && npm run test && npm run build",
    "preview": "vite preview",
    "docker:build": "docker compose build",
    "docker:up": "docker compose up -d --build",
    "package:release": "bash ./scripts/package-release.sh"
  },
  "dependencies": {
    "framer-motion": "^12.38.0",
    "lucide-react": "^1.0.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-router-dom": "^7.13.2",
    "recharts": "^3.8.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.1"
  }
}
